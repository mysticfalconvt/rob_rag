# Database - PostgreSQL with pgvector
# Production (in Docker, uses postgres-prod container)
DATABASE_URL="postgresql://robrag:robrag_prod_password_change_me@postgres-prod:5432/robrag_prod"

# PostgreSQL Credentials
POSTGRES_USER=robrag
POSTGRES_PASSWORD=robrag_prod_password_change_me
POSTGRES_DB=robrag_prod

# Dev Database (optional, for local development)
DEV_POSTGRES_USER=robrag
DEV_POSTGRES_PASSWORD=robrag_dev_password
DEV_POSTGRES_DB=robrag_dev

# LM Studio API Configuration
LM_STUDIO_API_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Vector Database - Using PostgreSQL pgvector (no Qdrant needed)
USE_POSTGRES_VECTORS=true

# Documents Storage
# Use /app/documents when running in Docker, or absolute path for local dev
DOCUMENTS_FOLDER_PATH=./documents

# Model Configuration
EMBEDDING_MODEL_NAME=nomic-embed-text
CHAT_MODEL_NAME=llama-3.2-1b-instruct

# Application
APP_NAME=RobRAG

# Authentication
# Generate SESSION_SECRET with: openssl rand -base64 32
SESSION_SECRET=your-random-secret-key-here

# Initial Admin User (auto-created on first launch if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Administrator

# Webhook Secret (for automated syncing from external cron services)
# Generate with: openssl rand -hex 32
# Used by: /api/webhooks/sync-all
WEBHOOK_SECRET=your-webhook-secret-here

# Google Calendar OAuth (optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Add both redirect URIs to the same Google OAuth app:
#   - http://localhost:3000/api/google/auth/callback (for local dev)
#   - https://your-domain.com/api/google/auth/callback (for production)
#
# GOOGLE_REDIRECT_URI is optional - if not set, it will be auto-detected from the request
# Only set this if you need to override the auto-detection
# GOOGLE_REDIRECT_URI=https://your-production-domain.com/api/google/auth/callback

# Internal Service Key (for Matrix/Scheduler internal API calls)
# Generate with: openssl rand -hex 32
# Used to authenticate internal requests from Matrix bot and scheduler
INTERNAL_SERVICE_KEY=your-internal-service-key-here

# Timezone (used for scheduling, calendar display, reminders)
USER_TIMEZONE=America/New_York

# Google OAuth (optional - for Calendar and Gmail)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Paperless-ngx (optional)
# PAPERLESS_URL=http://localhost:8000
# PAPERLESS_API_TOKEN=your-paperless-api-token

# Web Search (optional - SearXNG or Perplexica)
# SEARXNG_URL=http://localhost:8888
# PERPLEXICA_URL=http://localhost:3001

# Fast Chat Model (optional - separate model for auxiliary tasks like query routing, summarization)
# If not set, uses CHAT_MODEL_NAME for everything
# FAST_CHAT_MODEL_NAME=llama-3.2-1b-instruct
